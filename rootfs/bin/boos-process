#!/bin/sh

REQ_DIR="${1:-/run/boos/requests}"
RESULT_DIR="${2:-/run/boos/results}"
LOG_FILE="/var/log/boos.log"

mkdir -p "$REQ_DIR"
mkdir -p "$RESULT_DIR"

processed=0

for f in "$REQ_DIR"/req-*
do
    [ -f "$f" ] || continue

    cmd="$(grep '^command=' "$f" | cut -d '=' -f 2-)"

    if [ -z "$cmd" ]; then
        echo "[boos-process] invalid request: $f" >> "$LOG_FILE"
        rm -f "$f"
        continue
    fi

    result_file="$RESULT_DIR/$(basename "$f").out"

    echo "[boos-process] executing request: $cmd" >> "$LOG_FILE"
    /bin/boos-exec "$cmd" > "$result_file" 2>&1

    echo "Processed $f -> $result_file"
    cat "$result_file"

    rm -f "$f"
    processed=1
done

if [ "$processed" = "0" ]; then
    echo "No pending requests."
fi
