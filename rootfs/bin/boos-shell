#!/bin/sh
set -f

LOG_FILE="/var/log/boos.log"

log_msg() {
    ts="$(awk '{printf "%.3f", $1}' /proc/uptime)"
    echo "ts=$ts component=boos-shell $1" >> "$LOG_FILE"
}

export BOOS_REQUESTER=shell

echo "BoOS shell started."
echo "Type 'help' to see commands."

while true
do
    printf "boos> "
    read -r line

    [ -z "$line" ] && continue

    log_msg "event=input input=\"$line\""

    set -- $line
    cmd="$1"
    arg="$2"

    case "$cmd" in
        run)
            shift
            if [ -z "$1" ]; then
                echo "Usage: run <command>"
            else
                /bin/boos-exec "$@"
            fi
            ;;

        submit)
            shift
            if [ -z "$1" ]; then
                echo "Usage: submit <command> [args...]"
            else
                /bin/boos-exec submit "$@"
            fi
            ;;

        help|commands|status|log|caps|shell|poweroff|process|results|result|debug|daemons)
            /bin/boos-exec "$cmd" "$arg"
            ;;

        exit|quit)
            /bin/boos-exec poweroff
            ;;

        *)
            echo "Unknown command: $cmd"
            echo "Type 'help'."
            ;;
    esac
done
