#!/bin/sh

LOG_FILE="/var/log/boos.log"

log_msg() {
    echo "[boos-shell] $1" >> "$LOG_FILE"
}

echo "BoOS shell started."
echo "Type 'help' to see commands."

while true
do
    printf "boos> "
    read line

    [ -z "$line" ] && continue

    log_msg "input: $line"

    set -- $line
    cmd="$1"
    arg="$2"

    case "$cmd" in
        run)
            if [ -z "$arg" ]; then
                echo "Usage: run <command>"
            else
                /bin/boos-exec "$arg"
            fi
            ;;

        submit)
            if [ -z "$arg" ]; then
                echo "Usage: submit <command>"
            else
                /bin/boos-exec submit "$arg"
            fi
            ;;

        help|commands|status|log|caps|shell|poweroff|process|results)
            /bin/boos-exec "$cmd"
            ;;

        exit|quit)
            /bin/boos-exec poweroff
            ;;

        *)
            echo "Unknown command: $cmd"
            echo "Type 'help'."
            ;;
    esac
done
